    <mvc:View
        controllerName="z.wf.zwfmanagement.controller.Analytics"
        xmlns:mvc="sap.ui.core.mvc"
        xmlns="sap.m"
        xmlns:core="sap.ui.core"
        xmlns:microchart="sap.suite.ui.microchart"
        xmlns:layout="sap.ui.layout"
        xmlns:card="sap.ui.integration.widgets"
        xmlns:viz="sap.viz.ui5.controls"
        xmlns:viz.data="sap.viz.ui5.data"
        xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    >

    <Page
        title="{i18n>analyticsTitle}"
        showNavButton="true"
        navButtonPress=".onNavBackToDashboard"
    >

    <headerContent>
        <core:Fragment
            fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"
            type="XML"
        />
    </headerContent>

    <content>

    <VBox visible="{userRole>/isAdmin}">

    <!-- STATUS + VOLUME PANEL  PERFORMANCE + HEATMAP -->
    <core:Fragment
        fragmentName="z.wf.zwfmanagement.view.fragments.analytics.VolumeStatusPanel"
        type="XML"
    />

       <!-- PROCESS PERFORMANCE PANEL -->
     <core:Fragment
        fragmentName="z.wf.zwfmanagement.view.fragments.analytics.ProcessPerformancePanel"
        type="XML"/>

    <!-- AGING BOTTLENECK PANEL -->
    <core:Fragment
        fragmentName="z.wf.zwfmanagement.view.fragments.analytics.AgingBottleneckPanel"
        type="XML"
    />

    <!-- TOP LONGEST USER -->
    <core:Fragment
        fragmentName="z.wf.zwfmanagement.view.fragments.analytics.TopLongestUser"
        type="XML"
    />

    <!-- USER WORKLOAD -->
    <core:Fragment
        fragmentName="z.wf.zwfmanagement.view.fragments.analytics.UserWorkloadPanel"
        type="XML"
    />

    </VBox>

    </content>

    </Page>

    </mvc:View>