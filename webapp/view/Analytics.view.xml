<mvc:View
    controllerName="z.wf.zwfmanagement.controller.Analytics"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:microchart="sap.suite.ui.microchart"
    xmlns:layout="sap.ui.layout"
    xmlns:card="sap.ui.integration.widgets"
    xmlns:viz="sap.viz.ui5.controls"
xmlns:viz.data="sap.viz.ui5.data"
xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
>
    <Shell>
        <Page
            title="{i18n>analyticsTitle}"
            showNavButton="true"
            navButtonPress=".onNavBackToDashboard"
        >
            <headerContent>
                <core:Fragment
                    fragmentName="z.wf.zwfmanagement.view.fragments.LanguageSelect"
                    type="XML"
                />
            </headerContent>
            <HBox
                justifyContent="Center"
                width="100%"
            >
                <HeaderContainer
                    id="container2"
                    scroll="false"
                    width="auto"
                >
                    <TileContent footer="Total Open Tasks">
                        <content>
                            <NumericContent
                                valueColor="Neutral"
                                value="{
                                    path: '/WfTasks/$count',
                                    parameters: {
                                        $filter: 'TechnicalStatus eq \'READY\' or TechnicalStatus eq \'RESERVED\''
                                    }
                                }"
                                scale="Open"
                                icon="sap-icon://activity-2"
                            />
                        </content>
                    </TileContent>
                    <TileContent footer="Overdue/Critical Tasks">
                        <content>
                            <NumericContent
                                valueColor="Error"
                                value="{
                                    path: '/WfTasks/$count',
                                    parameters: {
                                        $filter: 'DaysToDeadline lt 0'
                                    }
                                }"
                                scale="Critical"
                                icon="sap-icon://alert"
                            />
                        </content>
                    </TileContent>
                    <TileContent footer="High Priority Tasks">
                        <content>
                            <NumericContent
                                valueColor="Critical"
                                value="{
                                    path: '/WfTasks/$count',
                                    parameters: {
                                        $filter: 'Priority eq \'1\''
                                    }
                                }"
                                scale="High"
                                icon="sap-icon://high-priority"
                            />
                        </content>
                    </TileContent>
                </HeaderContainer>
            </HBox>
         
            <!-- <Panel>
                <card:Card
                    manifest="./cards/calendarCard/manifest.json"
                    width="400px"
                    height="auto"
                />
            </Panel> -->
            <Panel>
                <card:Card
                    manifest="/cards/statusChart/manifest.json"
                    width="400px"
                    height="400px"
                />
                <card:Card
                    class="sapUiMediumMarginBegin"
                    manifest="/cards/barPriorityChart/manifest.json"
                    width="780px"
                    height="400px"
                />
            </Panel>
            <Panel class="sapUiMediumMarginTop">
        <viz:VizFrame
        id="idPerfChart"
        vizType="dual_combination"
        height="450px"
        width="55%"
         vizProperties="{
        title: {
            visible: true,
            text: 'Tasks Completed and Avg Cycle Time'
        }
        }"
        >
        
        <viz:dataset>
            <viz.data:FlattenedDataset data="{/PerfData}">
                <viz.data:dimensions>
                    <viz.data:DimensionDefinition
                        name="Month"
                        value="{Month}" />
                </viz.data:dimensions>

                <viz.data:measures>
                    <viz.data:MeasureDefinition
                        name="Completed"
                        value="{Completed}" />
                    <viz.data:MeasureDefinition
                        name="Avg Cycle (Days)"
                        value="{AvgCycle}" />
                </viz.data:measures>
            </viz.data:FlattenedDataset>
        </viz:dataset>

        <viz:feeds>
            <viz.feeds:FeedItem
                uid="primaryValues"
                type="Measure"
                values="Completed" />
            <viz.feeds:FeedItem
                uid="secondaryValues"
                type="Measure"
                values="Avg Cycle (Days)" />
            <viz.feeds:FeedItem
                uid="axisLabels"
                type="Dimension"
                values="Month" />
        </viz:feeds>

    </viz:VizFrame>
</Panel>
        </Page>
    </Shell>
</mvc:View>
