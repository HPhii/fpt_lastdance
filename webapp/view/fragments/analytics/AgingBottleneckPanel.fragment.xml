<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    <Panel
        class="sapUiSmallMargin statsPanel"
        headerText="Workflow Bottleneck Heatmap"
        width="98.5%"
        visible="{userRole>/isAdmin}"
    >
        <Panel>

<viz:VizFrame
    id="agingChart"
    vizType="stacked_bar"
    width="100%"
    height="400px"
>

<viz:dataset>

<viz.data:FlattenedDataset
    data="{agingModel>/AgingData}"
>

<viz.data:dimensions>

<viz.data:DimensionDefinition
    name="BusinessObject"
    value="{agingModel>BusinessObject}"
/>

</viz.data:dimensions>

<viz.data:measures>

<viz.data:MeasureDefinition
    name="0-2 Days"
    value="{agingModel>0-2Days}"
/>

<viz.data:MeasureDefinition
    name="3-7 Days"
    value="{agingModel>3-7Days}"
/>

<viz.data:MeasureDefinition
    name=">7 Days"
    value="{agingModel>Over7Days}"
/>

</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem
    uid="valueAxis"
    type="Measure"
    values="0-2 Days,3-7 Days,>7 Days"
/>

<viz.feeds:FeedItem
    uid="categoryAxis"
    type="Dimension"
    values="BusinessObject"
/>

</viz:feeds>

</viz:VizFrame>

</Panel>

        <FlexBox
            width="100%"
            direction="Column"
        >

            <viz:VizFrame
                id="BottleneckHeatmapChart"
                uiConfig="{applicationSet:'fiori'}"
                class="sapUiSmallMargin"
                width="100%"
                vizType="heatmap"
                vizProperties="{
                    plotArea:{
                        isScrollable:true
                    },
                    legend:{
                        visible:true
                    },
                    title:{
                        visible:true
                    },
                    interaction:{
                        selectability:{mode:'single'}
                    }
                }"
            >

                <viz:dataset>
                 <viz.data:FlattenedDataset
                            data="{
                                path:'agingModel>/HeatData'
                            }"
                        >
                        <viz.data:dimensions>

                            <viz.data:DimensionDefinition
                                name="Priority"
                                value="{PriorityLevel}"
                            />

                            <viz.data:DimensionDefinition
                                name="Aging"
                                value="{AgingBucket}"
                            />

                        </viz.data:dimensions>

                        <viz.data:measures>

                            <viz.data:MeasureDefinition
                                name="OpenTasks"
                                value="{IsOpenCount}"
                            />

                        </viz.data:measures>

                    </viz.data:FlattenedDataset>

                </viz:dataset>

                <viz:feeds>

                    <!-- X axis -->
                    <viz.feeds:FeedItem
                        uid="categoryAxis"
                        type="Dimension"
                        values="Priority"
                    />

                    <!-- Y axis -->
                    <viz.feeds:FeedItem
                        uid="categoryAxis2"
                        type="Dimension"
                        values="Aging"
                    />

                    <!-- Heat color -->
                    <viz.feeds:FeedItem
                        uid="color"
                        type="Measure"
                        values="OpenTasks"
                    />

                </viz:feeds>

                <viz:dependents>
                    <viz:Popover id="BottleneckPopover"/>
                </viz:dependents>

            </viz:VizFrame>

        </FlexBox>

    </Panel>

</core:FragmentDefinition>