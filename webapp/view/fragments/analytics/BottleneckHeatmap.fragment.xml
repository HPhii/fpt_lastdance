<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

    <Panel
        class="sapUiSmallMargin statsPanel"
        headerText="Workflow Bottleneck Heatmap"
        width="98.5%"
        visible="{userRole>/isAdmin}"
    >

        <FlexBox
            width="100%"
            direction="Column"
        >

            <!-- Bottleneck Heatmap -->
            <viz:VizFrame
                id="BottleneckHeatmapChart"
                uiConfig="{applicationSet:'fiori'}"
                class="sapUiSmallMargin"
                width="100%"
                vizType="heatmap"
                vizProperties="{
                    plotArea:{
                        isScrollable:true
                    },
                    legend:{
                        visible:true
                    },
                    title:{
                        visible:true
                    },
                    interaction:{
                        selectability:{mode:'single'}
                    }
                }"
            >

                <viz:dataset>

                    <viz.data:FlattenedDataset
                        data="{
                            path:'bottleneckAnalytics>/ZC_GSP26SAP02_WF_AGIG',
                            parameters:{
                                $select:'PriorityLevel,AgingBucket,IsOpenCount'
                            }
                        }"
                    >

                        <viz.data:dimensions>

                            <viz.data:DimensionDefinition
                                name="Priority"
                                value="{PriorityLevel}"
                            />

                            <viz.data:DimensionDefinition
                                name="Aging"
                                value="{AgingBucket}"
                            />

                        </viz.data:dimensions>

                        <viz.data:measures>

                            <viz.data:MeasureDefinition
                                name="OpenTasks"
                                value="{IsOpenCount}"
                            />

                        </viz.data:measures>

                    </viz.data:FlattenedDataset>

                </viz:dataset>

                <viz:feeds>

                    <!-- X axis -->
                    <viz.feeds:FeedItem
                        uid="categoryAxis"
                        type="Dimension"
                        values="Priority"
                    />

                    <!-- Y axis -->
                    <viz.feeds:FeedItem
                        uid="categoryAxis2"
                        type="Dimension"
                        values="Aging"
                    />

                    <!-- Heat color -->
                    <viz.feeds:FeedItem
                        uid="color"
                        type="Measure"
                        values="OpenTasks"
                    />

                </viz:feeds>

                <viz:dependents>
                    <viz:Popover id="BottleneckPopover"/>
                </viz:dependents>

            </viz:VizFrame>

        </FlexBox>

    </Panel>

</core:FragmentDefinition>