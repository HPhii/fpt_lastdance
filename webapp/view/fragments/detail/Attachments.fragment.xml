<core:FragmentDefinition
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
>
    <ObjectPageSection title="{i18n>attachmentsTitle} ({_Attachments/$count})">
        <subSections>
            <ObjectPageSubSection
                title="{i18n>attachmentsTitle} ({_Attachments/$count})"
            >
                <m:List
                    items="{
                        path: '_Attachments',
                        sorter: [
                            {
                                path: 'DateCreated',
                                descending: true
                            },
                            {
                                path: 'CreatedAt',
                                descending: true
                            }
                        ]
                    }"
                >
                    <m:headerToolbar>
                        <m:OverflowToolbar width="100%">
                            <m:ToolbarSpacer />
                            <m:Button
                                icon="sap-icon://upload"
                                text="{i18n>attachmentUpload}"
                                press=".onUploadAttachment"
                            />
                        </m:OverflowToolbar>
                    </m:headerToolbar>
                    <m:items>
                        <m:CustomListItem type="Active">
                            <m:HBox
                                alignItems="Start"
                                justifyContent="SpaceBetween"
                                class="sapUiSmallMargin"
                            >
                                <m:HBox
                                    justifyContent="Start"
                                    alignItems="Center"
                                >
                                    <core:Icon
                                        src="{
                                        path: 'FileExtension',
                                        formatter: '.formatter.formatAttachmentIcon'
                                    }"
                                        size="2rem"
                                        color="#0057d2"
                                        class="sapUiSmallMarginEnd"
                                    />
                                    <m:VBox>
                                        <m:Link
                                            text="{DocumentTitle}.{FileExtension}"
                                        />
                                        <m:HBox class="sapUiTinyMarginTop">
                                            <m:Text
                                                text="{DateCreated}, {CreatedAt}"
                                            />

                                            <m:Text
                                                text="{CreatedBy}"
                                                class="sapUiSmallMarginBeginEnd"
                                            />
                                            <m:Text
                                                text="{
                                                path: 'DocumentSize',
                                                formatter: '.formatter.formatFileSize'
                                            }"
                                            />
                                        </m:HBox>
                                    </m:VBox>
                                </m:HBox>
                                <m:Button
                                    icon="sap-icon://decline"
                                    press=".onRemoveAttachment"
                                    type="Transparent"
                                />
                            </m:HBox>
                        </m:CustomListItem>
                    </m:items>
                </m:List>
            </ObjectPageSubSection>
        </subSections>
    </ObjectPageSection>
</core:FragmentDefinition>
