{
  "_version": "1.83.1",
  "sap.app": {
    "id": "card.explorer.analytical.barWithReferenceLines.card",
    "type": "card",
    "title": "Sample of Bar Chart with Reference Lines",
    "subTitle": "Sample of Bar Chart with Reference Lines",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "shortTitle": "A short title for this Card",
    "info": "Additional information about this Card",
    "description": "A long description for this Card",
    "tags": {
      "keywords": ["Analytical", "Card", "Bar", "Sample"]
    }
  },
  "sap.ui": {
    "technology": "UI5"
  },
  "sap.card": {
    "type": "Analytical",
    "header": {
      "title": "Task in Processing by Priority"
    },
    "content": {
      "data": {
        "request": {
          "url": "/sap/opu/odata/sap/ZC_GSP26SAP02_WF_ANALYTICS_CDS/ZC_GSP26SAP02_WF_ANALYTICS?$select=PriorityLevel,TaskCounter&$filter=StatusCategory eq 'Open' or StatusCategory eq 'In Process'&$format=json"
        },
        "path": "/d/results"
      },
      "chartType": "bar",
      "chartProperties": {
        "title": {
          "visible": true,
          "text": "Task Count by Priority"
        },
        "legend": {
          "visible": false
        },
        "plotArea": {
          "dataPointStyle": {
            "rules": [
              {
                "dataContext": { "PriorityLevel": "High" },
                "properties": {
                  "color": "sapUiNegativeElement"
                }
              },
              {
                "dataContext": { "PriorityLevel": "Medium" },
                "properties": {
                  "color": "sapUiCriticalElement"
                }
              },
              {
                "dataContext": { "PriorityLevel": "Low" },
                "properties": {
                  "color": "sapUiPositiveElement"
                }
              }
            ]
          }
        }
      },
      "minHeight": "20rem",
      "dimensions": [
        {
          "name": "PriorityLevel",
          "value": "{PriorityLevel}"
        }
      ],
      "measures": [
        {
          "name": "TaskCounter",
          "value": "{TaskCounter}"
        }
      ],
      "feeds": [
        {
          "uid": "valueAxis",
          "type": "Measure",
          "values": ["TaskCounter"]
        },
        {
          "uid": "categoryAxis",
          "type": "Dimension",
          "values": ["PriorityLevel"]
        }
      ]
    }
  }
}
